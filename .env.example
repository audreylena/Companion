# Copy this file to .env.local and fill in real values (.env.local is gitignored).

# --- YouVersion Platform API ---
# Register: https://platform.youversion.com/summer-virtual-challenge-2026
# Then create an app in the Developers Portal and copy your Developer Token.
YOUVERSION_TOKEN=
# Confirm the base URL in your portal (2026 Platform may differ from the default in spike.mjs).
YOUVERSION_BASE=https://developers.youversionapi.com/1.0

# --- Gloo AI Studio API ---
# Register: https://studio.ai.gloo.com/challenge  ($20 credit, first 500)
# Get client id/secret + the exact token & base URLs from docs.gloo.com/api-reference
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=
GLOO_TOKEN_URL=https://platform.ai.gloo.com/oauth2/token
GLOO_BASE_URL=https://platform.ai.gloo.com/ai/v1
GLOO_MODEL=gloo-openai-gpt-5-mini
GLOO_SCOPE=api/access
